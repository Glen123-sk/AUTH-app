PORT=3000
CORS_ORIGIN=*
PUBLIC_APP_URL=http://localhost:5500/client
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_SERVICE_ACCOUNT_PATH=
# Or provide full JSON in one line (escaped) instead of path:
FIREBASE_SERVICE_ACCOUNT_JSON=

SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM_EMAIL=your-sender-email@example.com
SMTP_FROM_NAME=Auth App

EMAIL_AUTH_TABLE=email_auth_users
PENDING_SIGNUPS_TABLE=pending_signups
PASSWORD_RESETS_TABLE=password_resets

DEV_EXPOSE_LINKS=true