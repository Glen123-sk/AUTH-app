PORT=5000
NODE_ENV=development
TRUST_PROXY=true
USE_GITHUB_AUTH_ONLY=false
MONGO_URI=mongodb://localhost:27017/auth_smtp_app
# Production Atlas example:
# MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/auth_smtp_app?retryWrites=true&w=majority&appName=auth-smtp-app
# If your password has special characters, URL-encode them before placing them in MONGO_URI.
# If your MongoDB user was created in a different database, add authSource=<db> to the query string.
MONGO_CONNECT_RETRIES=5
MONGO_CONNECT_RETRY_DELAY_MS=3000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
RESET_TOKEN_EXPIRES_IN=10m
SESSION_EXPIRES_IN_DAYS=30

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Auth App <no-reply@example.com>"
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAME_SITE=lax
CORS_ORIGIN=https://nexl.me,https://www.nexl.me,http://localhost:5000,http://127.0.0.1:5000

# GitHub OAuth Configuration (optional but required for GitHub login)
# Get these credentials from: https://github.com/settings/developers/oauth-apps
# Create a new OAuth App with:
#   - Application name: Your App Name
#   - Homepage URL: http://localhost:5000 (for dev) or your production URL
#   - Authorization callback URL: http://localhost:5000/auth/github/callback
GITHUB_CLIENT_ID=Ov23liFKVPJM0EslslC3
GITHUB_CLIENT_SECRET=Ov23liFKVPJM0EslslC3
GITHUB_CALLBACK_URL=http://localhost:5000/auth/github/callback
GITHUB_FILE_DB_PATH=

TESTMAIL_NAMESPACE=your_testmail_namespace
TESTMAIL_API_KEY=your_testmail_api_key

