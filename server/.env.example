
# Application URL (used in email confirmation links)
APP_URL=http://localhost:5000
# Production environment configuration
PORT=5000
NODE_ENV=production
TRUST_PROXY=true
USE_GITHUB_AUTH_ONLY=true
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRES_IN=1d
SESSION_EXPIRES_IN_DAYS=30

# GitHub OAuth Configuration
# Get these credentials from: https://github.com/settings/developers/oauth-apps
# The callback URL MUST exactly match your GitHub OAuth app settings
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback

# GitHub API Database (set GITHUB_DB_MODE=api to use your GitHub repo as the user database)
GITHUB_DB_MODE=file
GITHUB_DB_OWNER=your_github_username_or_org
GITHUB_DB_REPO=your_repo_name
GITHUB_DB_BRANCH=main
GITHUB_DB_FILE_PATH=server/data/github-users.json
GITHUB_DB_EMAIL_FILE_PATH=server/data/email-auth.json
GITHUB_DB_TOKEN=your_github_personal_access_token
GITHUB_DB_COMMITTER_NAME=Auth App Bot
GITHUB_DB_COMMITTER_EMAIL=noreply@example.com

# Optional local fallback path when GITHUB_DB_MODE=file
EMAIL_AUTH_FILE_DB_PATH=

# CORS - set to your domain(s)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Session Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

