# Production environment configuration
PORT=5000
NODE_ENV=production
TRUST_PROXY=true
USE_GITHUB_AUTH_ONLY=true
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRES_IN=1d
SESSION_EXPIRES_IN_DAYS=30

# GitHub OAuth Configuration
# Get these credentials from: https://github.com/settings/developers/oauth-apps
# The callback URL MUST exactly match your GitHub OAuth app settings
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback

# CORS - set to your domain(s)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# Session Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

