NODE_ENV=production
PORT=5000
TRUST_PROXY=true
USE_GITHUB_AUTH_ONLY=true

JWT_SECRET=replace_with_very_long_random_secret
JWT_EXPIRES_IN=1d
RESET_TOKEN_EXPIRES_IN=10m
SESSION_EXPIRES_IN_DAYS=30
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAME_SITE=lax

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_REJECT_UNAUTHORIZED=true
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Auth App <no-reply@example.com>"

# Application URL (used in email confirmation links)
APP_URL=https://nexl.me

# GitHub OAuth (required when USE_GITHUB_AUTH_ONLY=true)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://nexl.me/auth/github/callback
GITHUB_FILE_DB_PATH=

# GitHub API Database (recommended for production)
GITHUB_DB_MODE=api
GITHUB_DB_OWNER=your_github_username_or_org
GITHUB_DB_REPO=your_repo_name
GITHUB_DB_BRANCH=main
GITHUB_DB_FILE_PATH=server/data/github-users.json
GITHUB_DB_EMAIL_FILE_PATH=server/data/email-auth.json
GITHUB_DB_TOKEN=your_github_personal_access_token
GITHUB_DB_COMMITTER_NAME=Auth App Bot
GITHUB_DB_COMMITTER_EMAIL=noreply@example.com

# Optional local fallback path when GITHUB_DB_MODE=file
EMAIL_AUTH_FILE_DB_PATH=

# Use your production frontend domain(s), comma-separated
CORS_ORIGIN=https://nexl.me,https://www.nexl.me
